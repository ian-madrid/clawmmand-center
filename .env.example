# 🔒 Environment Variables Template
# Copy this file to .env and fill in your REAL values
# NEVER commit .env to GitHub!

# User Location (PRIVATE - for distance calculations)
USER_LAT=40.7565
USER_LNG=-73.9670
USER_LOCATION="2nd Ave & 50th St, Manhattan, NYC"

# App Configuration
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="clawmmand-center"
NEXT_PUBLIC_VERSION="1.0.0"

# Data Source
# Use 'mock' for demo data, 'live' for API integration
NEXT_PUBLIC_DATA_MODE=mock

# Eventbrite API (optional - for real event data)
# EVENTBRITE_API_KEY=your-api-key-here
